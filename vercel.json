{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "handle": "filesystem"
    },
    {
      "source": "/((?!assets/|icons/|favicon\\.ico|favicon\\.svg|manifest\\.json|robots\\.txt|service-worker\\.js).*)",
      "destination": "/index.html"
    }
  ]
}
